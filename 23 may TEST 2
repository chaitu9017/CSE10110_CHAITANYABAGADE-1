23.
Find the Employee Name(s) who are assigned to the same projects as Employee ID 101.
SELECT DISTINCT Employees.employee_name
FROM Employees
INNER JOIN Assignments
ON Employees.employee_id = Assignments.employee_id
WHERE Assignments.project_id IN
(
    SELECT project_id
    FROM Assignments
    WHERE employee_id = 101
);